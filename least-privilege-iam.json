{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ConfigurationAuditing",
            "Effect": "Allow",
            "Action": [
                "s3:ListAllMyBuckets",
                "s3:GetBucketPublicAccessBlock",
                "ec2:DescribeSecurityGroups"
            ],
            "Resource": "*"
        },
        {
            "Sid": "LoggingAndAlerting",
            "Effect": "Allow",
            "Action": [
                "dynamodb:PutItem",
                "sns:Publish"
            ],
            "Resource": "*"
        }
    ]
}